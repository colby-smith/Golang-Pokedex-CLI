{
  "name": "Development Branch Rules",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/development"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false
      }
    },
    {
      "type": "deletion",
      "parameters": {
        "block_deletions": true
      }
    },
    {
      "type": "creation",
      "parameters": {
        "blocked_patterns": ["release/*", "hotfix/*"]
      }
    },
    {
      "type": "secret_scanning",
      "parameters": {
        "block_pushes": true
      }
    },
    {
      "type": "push_protection",
      "parameters": {
        "enabled": false
      }
    },
    {
      "type": "code_scanning",
      "parameters": {
        "enabled": true
      }
    },
    {
      "type": "dependency_review",
      "parameters": {
        "enabled": true
      }
    }
  ],
  "bypass_actors": []
}
